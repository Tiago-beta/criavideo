# Database (reuse Levita PostgreSQL)
DATABASE_URL=postgresql+asyncpg://levita:password@localhost:5432/levita

# JWT (same secret as Levita for shared auth)
JWT_SECRET=your_jwt_secret_here

# Google AI (Nano Banana - image generation)
GOOGLE_AI_API_KEY=your_google_ai_key_here

# xAI / Grok (video generation)
XAI_API_KEY=your_xai_key_here

# OpenAI (lyrics analysis)
OPENAI_API_KEY=your_openai_key_here

# Server
HOST=0.0.0.0
PORT=8000
SITE_URL=https://criavideo.pro

# Levita integration
LEVITA_STEMS_DIR=/opt/olevita/backend/stems
LEVITA_UPLOADS_DIR=/opt/olevita/backend/uploads

# Media storage
MEDIA_DIR=/opt/levita-video/media
