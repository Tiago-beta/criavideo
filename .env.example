# Database (reuse Levita PostgreSQL)
DATABASE_URL=postgresql+asyncpg://levita:password@localhost:5432/levita

# JWT (same secret as Levita for shared auth)
JWT_SECRET=your_jwt_secret_here
AUTH_TOKEN_EXPIRATION_HOURS=720

# Google AI (Nano Banana - image generation)
GOOGLE_AI_API_KEY=your_google_ai_key_here
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here
RISC_ALLOWED_AUDIENCES=your_google_oauth_client_id_here
RISC_ENDPOINT_PATH=/api/security/risc/events

# xAI / Grok (video generation)
XAI_API_KEY=your_xai_key_here

# Atlas Cloud (Seedance 2.0 + Wan)
ATLASCLOUD_API_KEY=your_atlascloud_api_key_here
ATLASCLOUD_API_BASE_URL=https://api.atlascloud.ai/api/v1
ATLASCLOUD_SEEDANCE_T2V_MODEL=bytedance/seedance-2.0/text-to-video
ATLASCLOUD_SEEDANCE_I2V_MODEL=bytedance/seedance-v1.5-pro/image-to-video-fast
ATLASCLOUD_WAN_T2V_MODEL=alibaba/wan-2.7/text-to-video
ATLASCLOUD_WAN_I2V_MODEL=alibaba/wan-2.6/image-to-video

# OpenAI (lyrics analysis)
OPENAI_API_KEY=your_openai_key_here

# Fish Audio (voice cloning)
FISH_AUDIO_API_KEY=your_fish_audio_key_here

# ElevenLabs (persona voice TTS)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Mercado Pago (credit purchases)
MP_ACCESS_TOKEN=your_mercado_pago_access_token_here

# Server
HOST=0.0.0.0
PORT=8000
SITE_URL=https://criavideo.pro
LEVITA_URL=https://levita.pro

# Levita integration
LEVITA_STEMS_DIR=/opt/olevita/backend/stems
LEVITA_UPLOADS_DIR=/opt/olevita/backend/uploads
LEVITA_API_TOKEN=
LEVITA_REMOVE_VOCALS_URL=

# Media storage
MEDIA_DIR=/opt/levita-video/media
