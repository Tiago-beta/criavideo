{
  "name": "criavideo-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Empacotamento Android do CriaVideo via Capacitor",
  "scripts": {
    "deploy:staging": "git push staging master",
    "verify:frontend:local": "powershell -ExecutionPolicy Bypass -File .\\scripts\\verify_frontend_bundle_sync.ps1",
    "verify:frontend:production": "powershell -ExecutionPolicy Bypass -File .\\scripts\\verify_frontend_bundle_sync.ps1 -CompareProduction",
    "verify:frontend:staging": "powershell -ExecutionPolicy Bypass -File .\\scripts\\verify_frontend_bundle_sync.ps1 -CompareStaging",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:copy": "npx cap copy",
    "android:build": "npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  }
}
